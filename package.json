{
  "name": "my-blog",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "lint": "next lint",
    "db:push": "wrangler d1 execute my-blog-db --remote --file=./schema.sql",
    "db:push:local": "wrangler d1 execute my-blog-db --local --file=./schema.sql",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 execute my-blog-db --remote --file=./drizzle/migrations/*.sql",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "drizzle-orm": "^0.33.0",
    "highlight.js": "^11.10.0",
    "iron-session": "^8.0.3",
    "next": "^15.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "shiki": "^1.12.0",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241018.0",
    "@eslint/eslintrc": "^3.3.5",
    "@next/eslint-plugin-next": "^16.2.9",
    "@opennextjs/cloudflare": "^1.20.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.8",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.24.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.12",
    "typescript": "^5.5.0",
    "wrangler": "^4.105.0"
  }
}